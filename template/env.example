# ─── Required — At least one API key ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── Optional — Pi configuration ──────────────────────────────────
# PI_MODEL=claude-sonnet-4-20250514          # Initial model (changeable via UI dropdown)
# PI_THINKING_LEVEL=off                      # off | minimal | low | medium | high | xhigh
# PI_RETRY_ENABLED=true                      # enable automatic retry on transient failures
# PI_RETRY_MAX_RETRIES=2                     # max auto-retries for a failed run
# ENABLE_CODING_TOOLS=false                  # enable backend read/bash/edit/write tools
# PI_CWD=/path/to/project                   # working directory for coding tools

# ─── Optional — Session persistence ──────────────────────────────
# ENABLE_SESSION_PERSISTENCE=false           # true to persist sessions to disk (JSONL)
# PI_SESSION_DIR=.pi-ag-ui-sessions          # directory for session files

# ─── Optional — Pi extensions ─────────────────────────────────────
# ENABLE_EXTENSIONS=false                    # true to load extensions from PI_AGENT_DIR
# PI_AGENT_DIR=~/.pi/agent                   # directory for Pi agent extensions

# ─── Optional — Debug & Middleware ─────────────────────────────────
# DEBUG_AGUI_EVENTS=true                     # Log all AG-UI events in server console
# DEBUG_AGUI_METRICS=true                    # Log run timing, event counts, tool durations
# DEBUG_RAW_EVENTS=true                      # Forward unhandled Pi events as RAW

# ─── Optional — Frontend ──────────────────────────────────────────
# NEXT_PUBLIC_APP_TITLE=Pi AG-UI
